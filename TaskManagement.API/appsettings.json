{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=TaskManagementDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "NM62PjFNTxaP1VEWoLdsMLE7lxiIcMDZ5paxFelARQv",
    "Issuer": "TaskManagement",
    "Audience": "TaskManagementUsers",
    "ExpiryMinutes": 60
  },
  "RefreshToken": {
    "ExpiryDays": 7
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "ExpiryMinutes": 10
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.ffff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.ffff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "TaskManagementAPI"
    }
  },
  "Json": {
    "DateTimeFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "AllowedHosts": "*"
}
